Declaring Methods Confidently:
# Standard Structural Setup
def add(a, b):
    return a + b

# Default Values
def greet(name="User"):
    return f"Hello, {name}"

# Type Annotations
def typed_add(a: int, b: int) -> int:
    return a + b

# Arbitrary Arguments (*args & **kwargs)
def process_data(*args, **kwargs):
    # args targets a tuple, kwargs targets a dictionary
    pass

# Lambda (Inline Expressions)
square = lambda x: x * x
